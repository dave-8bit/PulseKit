{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "rootDir": "./src",
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "outDir": "dist"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}

